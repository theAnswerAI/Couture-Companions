          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "                    Companion Couture was founded in Geneva in the winter of 1912 by Baroness Helena von Closen. Refusing to allow the magnificent working dog lineages of Europe to decline, she established a private sanctuary in the Swiss Alps to preserve genetic health and nurture noble temperaments."
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "                  </p>"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
