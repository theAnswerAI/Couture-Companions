        }
        lines {
          text: "                    <h4 className=\"font-serif text-stone-900 font-medium uppercase tracking-wide\">"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "                      THE COMPANION COUTURE GUARDIAN AGREEMENT"
